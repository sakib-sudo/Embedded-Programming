#include<stdio.h>
#include<stdlib.h>
int main(){
int n;
float *reading, sum = 0;
printf("How many readings?");
scanf("%d",&n};
readings = (float*)malloc(n*sizeof(float));
it(readings = NULL){
printf("memory allocation failed\n");
return 1;
)
for(int i=0; i<n; i++){
printf("reading %d", i+1);
scanf("%f"readings+i);
sum += *(readings+i);
}
printf("Average Temperature :%.2f", sum/n);
free(readings);
return 0;
}
